# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+asyncpg://awb:awb@localhost:5432/awb

# Redis (matches docker-compose.yml defaults)
REDIS_URL=redis://localhost:6379/0

# Anthropic API
ANTHROPIC_API_KEY=

# Engine
RUN_TOKEN_BUDGET=50000
